{
  "manifest_version": 3,
  "name": "Fic Downloader",
  "version": "0.1.0",
  "description": "Download fan fiction from AO3, FFN, and more in your preferred format.",

  "permissions": ["downloads", "activeTab", "storage", "scripting", "alarms"],
  "host_permissions": [
    "*://*.archiveofourown.org/*",
    "*://*.fanfiction.net/*",
    "*://*.royalroad.com/*",
    "*://*.royalroadcdn.com/*",
    "*://*.tapas.io/*",
    "*://*.scribblehub.com/*",
    "*://*.wattpad.com/*",
    "*://*.spacebattles.com/*",
    "*://*.sufficientvelocity.com/*",
    "*://*.questionablequesting.com/*"
  ],

  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },

  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Fic Downloader",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.archiveofourown.org/works/*",
        "*://*.fanfiction.net/s/*",
        "*://*.royalroad.com/fiction/*",
        "*://*.tapas.io/series/*",
        "*://*.scribblehub.com/series/*",
        "*://*.wattpad.com/story/*",
        "*://*.spacebattles.com/threads/*",
        "*://*.sufficientvelocity.com/threads/*",
        "*://*.questionablequesting.com/threads/*"
      ],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
