{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "types": ["firefox-webext-browser"],
    "skipLibCheck": true
  },
  "include": ["src/**/*", "manifest.json", "vite.config.ts"]
}
